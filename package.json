{
	"name": "supabase-react-template",
	"private": true,
	"version": "1.3.0",
	"type": "module",
	"scripts": {
		"dev": "rm -rf node_modules/.vite && NODE_ENV=development bun run --hot server.ts",
		"build": "rm -rf node_modules/.vite && node node_modules/typescript/bin/tsc && vite build",
		"prod": "bun run build && NODE_ENV=production bun run server.ts",
		"lint": "eslint .",
		"preview": "vite preview"
	},
	"dependencies": {
		"@supabase/supabase-js": "^2.47.3",
		"framer-motion": "^12.40.0",
		"lucide-react": "^0.468.0",
		"pino": "^10.1.0",
		"react": "^18.3.1",
		"react-dom": "^18.3.1",
		"react-router": "^7.1.0",
		"hono": "^4.12.30"
	},
	"devDependencies": {
		"@elementor/sandbox-dev-scripts-injector": "latest",
		"@eslint/js": "^9.16.0",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^22.10.2",
		"@types/react": "^18.3.13",
		"@types/react-dom": "^18.3.1",
		"@vitejs/plugin-react-swc": "^4.0.0",
		"eslint": "^9.16.0",
		"eslint-plugin-react-hooks": "^5.0.0",
		"eslint-plugin-react-refresh": "^0.4.16",
		"globals": "^15.12.0",
		"supabase": "^2.58.6",
		"tailwindcss": "^4.1.18",
		"typescript": "~5.6.2",
		"typescript-eslint": "^8.19.0",
		"vite": "^6.0.3"
	}
}
