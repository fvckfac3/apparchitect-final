{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apparchitect.dev/schemas/03-feature.schema.json",

  "title": "AppArchitect Feature Schema",
  "description": "Canonical feature definition contract. Features are the atomic product units from which workflows, screens, APIs, architecture, validation, testing, documentation, and roadmap artifacts are generated.",

  "type": "object",

  "required": [
    "metadata",
    "references",
    "content"
  ],

  "properties": {

    "metadata": {
      "$ref": "#/$defs/artifactMetadata"
    },

    "references": {
      "$ref": "#/$defs/referenceModel"
    },

    "content": {
      "$ref": "#/$defs/featureContent"
    }
  },

  "$defs": {

    "artifactMetadata": {

      "type": "object",

      "required": [
        "id",
        "artifact_type",
        "name",
        "version",
        "status",
        "owner",
        "created_at",
        "updated_at"
      ],

      "properties": {

        "id": {
          "type": "string",
          "pattern": "^feature_[a-zA-Z0-9_-]+$"
        },

        "artifact_type": {
          "const": "feature"
        },

        "name": {
          "type": "string",
          "minLength": 3
        },

        "version": {
          "$ref": "#/$defs/version"
        },

        "status": {
          "$ref": "#/$defs/status"
        },

        "owner": {
          "$ref": "#/$defs/owner"
        },

        "created_at": {
          "type": "string",
          "format": "date-time"
        },

        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "version": {

      "type": "object",

      "required": [
        "major",
        "minor",
        "patch"
      ],

      "properties": {

        "major": {
          "type": "integer",
          "minimum": 0
        },

        "minor": {
          "type": "integer",
          "minimum": 0
        },

        "patch": {
          "type": "integer",
          "minimum": 0
        }
      }
    },

    "status": {

      "type": "string",

      "enum": [
        "draft",
        "in_progress",
        "generated",
        "validated",
        "approved",
        "exported",
        "deprecated"
      ]
    },

    "owner": {

      "type": "string",

      "enum": [
        "Discovery Agent",
        "Schema Agent",
        "Architecture Agent",
        "Workflow Agent",
        "UX Agent",
        "Documentation Agent",
        "Validation Agent",
        "Export Agent",
        "Governance Layer"
      ]
    },

    "referenceModel": {

      "type": "object",

      "properties": {

        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "dependent_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "validation_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "featureContent": {

      "type": "object",

      "required": [
        "feature_id",
        "feature_name",
        "category",
        "description",
        "business_value",
        "priority",
        "user_stories",
        "acceptance_criteria"
      ],

      "properties": {

        "feature_id": {
          "type": "string"
        },

        "feature_name": {
          "type": "string"
        },

        "feature_slug": {
          "type": "string"
        },

        "category": {

          "type": "string",

          "enum": [
            "authentication",
            "user_management",
            "ai",
            "workflow",
            "analytics",
            "billing",
            "notification",
            "content",
            "search",
            "integration",
            "security",
            "administration",
            "reporting",
            "collaboration",
            "other"
          ]
        },

        "description": {
          "type": "string"
        },

        "problem_statement": {
          "type": "string"
        },

        "business_value": {
          "type": "string"
        },

        "user_value": {
          "type": "string"
        },

        "priority": {

          "type": "string",

          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        },

        "status": {

          "type": "string",

          "enum": [
            "proposed",
            "approved",
            "planned",
            "in_development",
            "released",
            "deprecated"
          ]
        },

        "complexity": {

          "type": "string",

          "enum": [
            "very_low",
            "low",
            "medium",
            "high",
            "very_high"
          ]
        },

        "effort_estimate": {
          "type": "integer",
          "minimum": 1
        },

        "dependencies": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "blocks": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "personas": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "roles": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "user_stories": {

          "type": "array",

          "minItems": 1,

          "items": {
            "$ref": "#/$defs/userStory"
          }
        },

        "acceptance_criteria": {

          "type": "array",

          "minItems": 1,

          "items": {
            "$ref": "#/$defs/acceptanceCriterion"
          }
        },

        "business_rules": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/businessRule"
          }
        },

        "workflows": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "screens": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "api_contracts": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "data_entities": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "events": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/eventDefinition"
          }
        },

        "analytics": {
          "$ref": "#/$defs/analyticsDefinition"
        },

        "security": {
          "$ref": "#/$defs/securityDefinition"
        },

        "ai_requirements": {
          "$ref": "#/$defs/aiRequirements"
        },

        "test_requirements": {
          "$ref": "#/$defs/testRequirements"
        },

        "roadmap": {
          "$ref": "#/$defs/roadmapMetadata"
        }
      }
    },

    "userStory": {

      "type": "object",

      "required": [
        "id",
        "story"
      ],

      "properties": {

        "id": {
          "type": "string"
        },

        "story": {
          "type": "string"
        },

        "persona": {
          "type": "string"
        },

        "priority": {
          "type": "string"
        }
      }
    },

    "acceptanceCriterion": {

      "type": "object",

      "required": [
        "id",
        "criterion"
      ],

      "properties": {

        "id": {
          "type": "string"
        },

        "criterion": {
          "type": "string"
        },

        "testable": {
          "type": "boolean"
        }
      }
    },

    "businessRule": {

      "type": "object",

      "properties": {

        "id": {
          "type": "string"
        },

        "rule": {
          "type": "string"
        },

        "severity": {

          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        }
      }
    },

    "eventDefinition": {

      "type": "object",

      "properties": {

        "event_name": {
          "type": "string"
        },

        "trigger": {
          "type": "string"
        },

        "payload": {
          "type": "object"
        }
      }
    },

    "analyticsDefinition": {

      "type": "object",

      "properties": {

        "track_usage": {
          "type": "boolean"
        },

        "events": {
          "type": "array"
        },

        "kpis": {
          "type": "array"
        }
      }
    },

    "securityDefinition": {

      "type": "object",

      "properties": {

        "authentication_required": {
          "type": "boolean"
        },

        "authorization_required": {
          "type": "boolean"
        },

        "sensitive_data": {
          "type": "boolean"
        }
      }
    },

    "aiRequirements": {

      "type": "object",

      "properties": {

        "ai_enabled": {
          "type": "boolean"
        },

        "provider": {
          "type": "string"
        },

        "model_requirements": {
          "type": "array"
        }
      }
    },

    "testRequirements": {

      "type": "object",

      "properties": {

        "unit_tests_required": {
          "type": "boolean"
        },

        "integration_tests_required": {
          "type": "boolean"
        },

        "e2e_tests_required": {
          "type": "boolean"
        }
      }
    },

    "roadmapMetadata": {

      "type": "object",

      "properties": {

        "release_phase": {
          "type": "string"
        },

        "target_milestone": {
          "type": "string"
        }
      }
    }
  },

  "examples": [
    {
      "metadata": {
        "id": "feature_discovery_engine",
        "artifact_type": "feature",
        "name": "Discovery Engine"
      },

      "content": {

        "feature_id": "F-001",

        "feature_name": "Discovery Engine",

        "category": "ai",

        "priority": "critical",

        "user_stories": [
          {
            "id": "US-001",
            "story": "As a founder I want the platform to interview me so that my idea can be converted into a project schema."
          }
        ],

        "acceptance_criteria": [
          {
            "id": "AC-001",
            "criterion": "System captures all required schema fields."
          }
        ]
      }
    }
  ]
}
