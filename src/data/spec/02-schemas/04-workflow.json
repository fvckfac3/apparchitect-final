{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://apparchitect.dev/schemas/04-workflow.schema.json",

  "title": "AppArchitect Workflow Schema",
  "description": "Canonical workflow contract. Defines user workflows, system workflows, agent workflows, orchestration flows, state transitions, decision trees, exception handling, and execution requirements.",

  "type": "object",

  "required": [
    "metadata",
    "references",
    "content"
  ],

  "properties": {
    "metadata": {
      "$ref": "#/$defs/artifactMetadata"
    },

    "references": {
      "$ref": "#/$defs/referenceModel"
    },

    "content": {
      "$ref": "#/$defs/workflowContent"
    }
  },

  "$defs": {

    "artifactMetadata": {
      "type": "object",

      "required": [
        "id",
        "artifact_type",
        "name",
        "version",
        "status",
        "owner",
        "created_at",
        "updated_at"
      ],

      "properties": {

        "id": {
          "type": "string",
          "pattern": "^workflow_[a-zA-Z0-9_-]+$"
        },

        "artifact_type": {
          "const": "workflow"
        },

        "name": {
          "type": "string"
        },

        "version": {
          "$ref": "#/$defs/version"
        },

        "status": {
          "$ref": "#/$defs/status"
        },

        "owner": {
          "$ref": "#/$defs/owner"
        },

        "created_at": {
          "type": "string",
          "format": "date-time"
        },

        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },

    "version": {
      "type": "object",

      "required": [
        "major",
        "minor",
        "patch"
      ],

      "properties": {

        "major": {
          "type": "integer"
        },

        "minor": {
          "type": "integer"
        },

        "patch": {
          "type": "integer"
        }
      }
    },

    "status": {
      "type": "string",

      "enum": [
        "draft",
        "in_progress",
        "generated",
        "validated",
        "approved",
        "exported",
        "deprecated"
      ]
    },

    "owner": {
      "type": "string",

      "enum": [
        "Workflow Agent",
        "Architecture Agent",
        "Validation Agent",
        "Governance Layer"
      ]
    },

    "referenceModel": {
      "type": "object",

      "properties": {

        "source_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "dependent_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },

        "validation_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },

    "workflowContent": {

      "type": "object",

      "required": [
        "workflow_id",
        "workflow_name",
        "workflow_type",
        "actors",
        "states",
        "steps",
        "transitions"
      ],

      "properties": {

        "workflow_id": {
          "type": "string"
        },

        "workflow_name": {
          "type": "string"
        },

        "workflow_type": {

          "type": "string",

          "enum": [
            "user",
            "system",
            "agent",
            "backend",
            "integration",
            "approval",
            "generation",
            "validation",
            "export"
          ]
        },

        "description": {
          "type": "string"
        },

        "objective": {
          "type": "string"
        },

        "actors": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/actor"
          }
        },

        "triggers": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/trigger"
          }
        },

        "states": {

          "type": "array",

          "minItems": 1,

          "items": {
            "$ref": "#/$defs/state"
          }
        },

        "steps": {

          "type": "array",

          "minItems": 1,

          "items": {
            "$ref": "#/$defs/workflowStep"
          }
        },

        "decision_points": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/decisionPoint"
          }
        },

        "transitions": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/transition"
          }
        },

        "failure_paths": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/failurePath"
          }
        },

        "recovery_paths": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/recoveryPath"
          }
        },

        "outputs": {

          "type": "array",

          "items": {
            "$ref": "#/$defs/output"
          }
        },

        "dependencies": {

          "type": "array",

          "items": {
            "type": "string"
          }
        },

        "sla": {
          "$ref": "#/$defs/sla"
        },

        "validation_requirements": {
          "$ref": "#/$defs/validationRequirements"
        }
      }
    },

    "actor": {

      "type": "object",

      "required": [
        "id",
        "name",
        "actor_type"
      ],

      "properties": {

        "id": {
          "type": "string"
        },

        "name": {
          "type": "string"
        },

        "actor_type": {

          "enum": [
            "user",
            "admin",
            "service",
            "agent",
            "external_system"
          ]
        }
      }
    },

    "trigger": {

      "type": "object",

      "properties": {

        "trigger_id": {
          "type": "string"
        },

        "trigger_type": {

          "enum": [
            "user_action",
            "system_event",
            "schedule",
            "api_event",
            "webhook",
            "agent_action"
          ]
        },

        "description": {
          "type": "string"
        }
      }
    },

    "state": {

      "type": "object",

      "required": [
        "state_id",
        "state_name"
      ],

      "properties": {

        "state_id": {
          "type": "string"
        },

        "state_name": {
          "type": "string"
        },

        "is_initial": {
          "type": "boolean"
        },

        "is_terminal": {
          "type": "boolean"
        }
      }
    },

    "workflowStep": {

      "type": "object",

      "required": [
        "step_id",
        "step_name",
        "step_type"
      ],

      "properties": {

        "step_id": {
          "type": "string"
        },

        "step_name": {
          "type": "string"
        },

        "step_type": {

          "enum": [
            "input",
            "process",
            "decision",
            "api_call",
            "validation",
            "notification",
            "generation",
            "export"
          ]
        },

        "description": {
          "type": "string"
        },

        "owner": {
          "type": "string"
        },

        "expected_output": {
          "type": "string"
        }
      }
    },

    "decisionPoint": {

      "type": "object",

      "properties": {

        "decision_id": {
          "type": "string"
        },

        "question": {
          "type": "string"
        },

        "branches": {
          "type": "array"
        }
      }
    },

    "transition": {

      "type": "object",

      "required": [
        "from_state",
        "to_state"
      ],

      "properties": {

        "from_state": {
          "type": "string"
        },

        "to_state": {
          "type": "string"
        },

        "condition": {
          "type": "string"
        }
      }
    },

    "failurePath": {

      "type": "object",

      "properties": {

        "failure_id": {
          "type": "string"
        },

        "cause": {
          "type": "string"
        },

        "severity": {

          "enum": [
            "critical",
            "high",
            "medium",
            "low"
          ]
        }
      }
    },

    "recoveryPath": {

      "type": "object",

      "properties": {

        "recovery_id": {
          "type": "string"
        },

        "strategy": {
          "type": "string"
        }
      }
    },

    "output": {

      "type": "object",

      "properties": {

        "output_id": {
          "type": "string"
        },

        "artifact_type": {
          "type": "string"
        },

        "description": {
          "type": "string"
        }
      }
    },

    "sla": {

      "type": "object",

      "properties": {

        "target_execution_time_seconds": {
          "type": "number"
        },

        "success_rate_target": {
          "type": "number",
          "minimum": 0,
          "maximum": 100
        }
      }
    },

    "validationRequirements": {

      "type": "object",

      "properties": {

        "validation_required": {
          "type": "boolean"
        },

        "blocking_failures": {
          "type": "boolean"
        }
      }
    }
  },

  "examples": [
    {
      "metadata": {
        "id": "workflow_discovery_interview",
        "artifact_type": "workflow",
        "name": "Discovery Interview Workflow"
      },

      "content": {

        "workflow_id": "WF-001",

        "workflow_name": "Founder Discovery",

        "workflow_type": "generation",

        "actors": [
          {
            "id": "founder",
            "name": "Founder",
            "actor_type": "user"
          },
          {
            "id": "discovery_agent",
            "name": "Discovery Agent",
            "actor_type": "agent"
          }
        ],

        "states": [
          {
            "state_id": "start",
            "state_name": "Discovery Started",
            "is_initial": true
          },
          {
            "state_id": "complete",
            "state_name": "Schema Generated",
            "is_terminal": true
          }
        ]
      }
    }
  ]
}
