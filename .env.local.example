# Copy this file to .env.local for local development.
# .env.local is gitignored — never commit real secrets.
#
# For production, set these in Zo Settings > Advanced instead of relying
# on .env.local. Vite inlines VITE_* env vars at build time, so the
# deployed bundle reads from the build-time values, not from a runtime
# .env.local.

# --- Supabase ---
# Get these from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=

# --- AI providers ---
# Primary: Anthropic (Claude). Get from https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# Fallback: DeepSeek. Get from https://platform.deepseek.com/
VITE_DEEPSEEK_API_KEY=

# Optional: override provider selection
VITE_AI_PRIMARY=anthropic
VITE_AI_FALLBACK=deepseek
